{
  "trailingSlash": false,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.jele.at" }],
      "destination": "https://jele.at/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.jele.at" }],
      "destination": "https://jele.at/:path*",
      "permanent": true
    }
  ]
}
